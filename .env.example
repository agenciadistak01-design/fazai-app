# ============================================
# FAZAÍ — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# ============================================

# Claude API (obrigatório)
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX

# Supabase (obrigatório)
# Pegue em: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Kiwify Webhook (para liberar acesso após pagamento)
KIWIFY_WEBHOOK_SECRET=seu-webhook-secret

# URL base do app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare (para deploy automático dos sites — opcional no MVP)
# CLOUDFLARE_API_TOKEN=xxxxx
# CLOUDFLARE_ACCOUNT_ID=xxxxx
